{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/login", "destination": "/account/login", "permanent": false },
    { "source": "/register", "destination": "/account/register", "permanent": false }
  ],
  "rewrites": [
    { "source": "/", "destination": "/landing.html" },
    { "source": "/account/login/auth", "destination": "http://localhost:2000/account/login/auth" },
    { "source": "/api/:path*", "destination": "http://localhost:2000/api/:path*" }
  ]
}
